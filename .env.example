# ─── REQUERIDAS (la app NO inicia sin estas) ───────────────────────────────

# Clave secreta para JWT — mínimo 32 caracteres
# Genera una con: openssl rand -hex 32
JWT_SECRET_KEY=REEMPLAZA_CON_TU_CLAVE_SECRETA_DE_AL_MENOS_32_CHARS

# URL de base de datos PostgreSQL
# En Fly.io se configura automáticamente con: fly postgres attach <db-name>
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# ─── CONTRASEÑAS DE USUARIOS (REQUERIDAS) ────────────────────────────────────

# Contraseña del cajero de la tienda Tunal
TUNAL_SELLER_PASSWORD=CambiaEstaContraseña

# Contraseña del cajero de la tienda 20 de Julio
SELLER_20J_PASSWORD=CambiaEstaContraseña

# ─── CONTRASEÑAS OPCIONALES ──────────────────────────────────────────────────

# Contraseña del administrador
ADMIN_DEFAULT_PASSWORD=CambiaEstaContraseña

# Contraseña genérica de vendedor
SELLER_DEFAULT_PASSWORD=CambiaEstaContraseña

# ─── OPCIONALES (tienen valores por defecto) ─────────────────────────────────

# PORT=5000
# CASH_CLOSING_THRESHOLD=50000
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=1440
